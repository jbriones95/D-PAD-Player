<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base DPadPlayer theme — shared window/error settings.
      Each accent variant overrides primary/secondary/surface tokens.
    -->
    <style name="Theme.DPadPlayer.Base" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Error -->
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">#000000</item>

        <!-- Status / nav bar -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>

        <!-- No title bar -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- ── Deep Purple (default) ──────────────────────────────────────── -->
    <style name="Theme.DPadPlayer" parent="Theme.DPadPlayer.Base">
        <item name="colorPrimary">@color/deep_purple_primary</item>
        <item name="colorPrimaryVariant">@color/deep_purple_secondaryVariant</item>
        <item name="colorOnPrimary">@color/deep_purple_onPrimary</item>
        <item name="colorSecondary">@color/deep_purple_secondary</item>
        <item name="colorSecondaryVariant">@color/deep_purple_secondaryVariant</item>
        <item name="colorOnSecondary">@color/deep_purple_onPrimary</item>
        <item name="android:colorBackground">@color/deep_purple_surface</item>
        <item name="colorSurface">@color/deep_purple_surface</item>
        <item name="colorOnSurface">@color/deep_purple_onSurface</item>
        <item name="colorSurfaceVariant">@color/deep_purple_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/deep_purple_onSurfaceVariant</item>
    </style>

