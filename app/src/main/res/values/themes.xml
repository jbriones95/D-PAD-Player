<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Deep purple accent, dark-night Material2 theme.
      Manually provides all colorSurface* tokens that Material2 lacks.
    -->
    <style name="Theme.DPadPlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">#BB86FC</item>
        <item name="colorPrimaryVariant">#3700B3</item>
        <item name="colorOnPrimary">#000000</item>

        <!-- Secondary -->
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Background / surface -->
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#FFFFFFFF</item>

        <!-- Material2 does not define colorSurfaceVariant by default; add it manually -->
        <item name="colorSurfaceVariant">#2D2B34</item>
        <item name="colorOnSurfaceVariant">#CAC4D0</item>

        <!-- Error -->
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">#000000</item>

        <!-- Status / nav bar -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>

        <!-- No title bar -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
