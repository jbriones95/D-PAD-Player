<?xml version="1.0" encoding="utf-8"?>
<!--
  Item background for all focusable list rows.

  Layers (bottom → top):
    1. Focused solid — colorPrimary @ ~18% alpha (state_selected used as our focus proxy
       since isSelected=hasFocus is set in every VH's onFocusChangeListener)
    2. Activated solid — colorPrimary @ 12% alpha (currently-playing indicator)
    3. Ripple — standard touch feedback

  NOTE: state_selected is repurposed here as the "has D-pad focus" flag.
        Every adapter VH sets  view.isSelected = hasFocus  in its onFocusChangeListener.
        This means we get a permanent visible highlight while focused, not just a fleeting ripple.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?attr/colorControlHighlight">

    <!-- Focused (D-pad) overlay: state_selected = hasFocus -->
    <item android:id="@android:id/background">
        <selector>
            <item android:state_activated="true">
                <!-- currently playing track -->
                <shape android:shape="rectangle">
                    <solid android:color="#1F6750A4" />
                </shape>
            </item>
            <item android:state_selected="true">
                <!-- D-pad focus highlight -->
                <shape android:shape="rectangle">
                    <solid android:color="#2E6750A4" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </selector>
    </item>

</ripple>
