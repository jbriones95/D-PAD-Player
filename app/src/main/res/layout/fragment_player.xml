<?xml version="1.0" encoding="utf-8"?>
<!--
  Full now-playing screen inspired by Auxio.
  Layout (portrait, 369x492dp device):
    - Top bar: back + track counter                     ~44dp
    - Album art: square, full width                     ~180dp
    - Title / Artist (marquee)                          ~52dp
    - Seekbar row                                       ~32dp
    - Controls row: repeat | prev | play | next | shuffle  ~52dp
  Focus chain: back → play (default) → transport row → seekbar → back
  D-pad LEFT/RIGHT on seekbar scrubs. BACK key pops fragment.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ── Top bar ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="12dp"
        android:background="?attr/colorSurfaceVariant">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:text=""
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusDown="@id/btn_play"
            android:contentDescription="Back to library" />

        <TextView
            android:id="@+id/tv_track_counter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:gravity="center" />

        <View android:layout_width="44dp" android:layout_height="44dp" />
    </LinearLayout>

    <!-- ── Album art ────────────────────────────────────────────────── -->
    <ImageView
        android:id="@+id/album_art"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_note"
        android:contentDescription="Album art" />

    <!-- ── Info + controls panel ────────────────────────────────────── -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical">

        <!-- Title — marquee like Auxio -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No track"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:maxLines="1"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:gravity="center"
            android:focusable="false" />

        <!-- Artist -->
        <TextView
            android:id="@+id/tv_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?android:attr/textColorSecondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="2dp" />

        <!-- Album -->
        <TextView
            android:id="@+id/tv_album"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorSecondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="1dp" />

        <!-- Seekbar row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tv_position"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textSize="10sp"
                android:gravity="start" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusUp="@id/btn_back"
                android:nextFocusDown="@id/btn_play" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Transport controls row: repeat | prev | play | next | shuffle -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <!-- Repeat toggle -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_repeat"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_repeat_off"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusRight="@id/btn_prev"
                android:nextFocusLeft="@id/btn_shuffle"
                android:nextFocusUp="@id/seek_bar"
                android:contentDescription="Repeat mode" />

            <!-- Prev -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_prev"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_skip_previous"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusLeft="@id/btn_repeat"
                android:nextFocusRight="@id/btn_play"
                android:nextFocusUp="@id/seek_bar" />

            <!-- Play/Pause (wider, filled) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play"
                style="@style/Widget.MaterialComponents.Button.Icon"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusLeft="@id/btn_prev"
                android:nextFocusRight="@id/btn_next"
                android:nextFocusUp="@id/btn_back"
                android:nextFocusDown="@id/seek_bar" />

            <!-- Next -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_skip_next"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusLeft="@id/btn_play"
                android:nextFocusRight="@id/btn_shuffle"
                android:nextFocusUp="@id/seek_bar" />

            <!-- Shuffle toggle -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_shuffle"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_shuffle_off"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusLeft="@id/btn_next"
                android:nextFocusRight="@id/btn_repeat"
                android:nextFocusUp="@id/seek_bar"
                android:contentDescription="Shuffle" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
