<?xml version="1.0" encoding="utf-8"?>
<!--
  Full now-playing screen.
  Large album art takes ~40% of height, then info + seekbar + controls.
  Back button (top-left) + D-pad Back both return to LibraryFragment.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Top bar: back button + track counter -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:background="?attr/colorSurfaceVariant">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:text=""
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:contentDescription="Back to library" />

        <TextView
            android:id="@+id/tv_track_counter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:gravity="center" />

        <!-- spacer to balance the back button -->
        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <!-- Album art: square, fills width -->
    <ImageView
        android:id="@+id/album_art"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_note"
        android:contentDescription="Album art" />

    <!-- Info + controls panel -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:paddingStart="@dimen/player_padding_h"
        android:paddingEnd="@dimen/player_padding_h"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No track"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center" />

        <!-- Artist -->
        <TextView
            android:id="@+id/tv_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="2dp" />

        <!-- Album -->
        <TextView
            android:id="@+id/tv_album"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="2dp" />

        <!-- Seekbar row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/player_seek_row_height"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_position"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textSize="10sp"
                android:gravity="start" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="false" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Transport controls -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/player_control_btn_height"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_prev"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_skip_previous"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusRight="@id/btn_seek_bwd" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_seek_bwd"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_fast_rewind"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusLeft="@id/btn_prev"
                android:nextFocusRight="@id/btn_play" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play"
                style="@style/Widget.MaterialComponents.Button.Icon"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusLeft="@id/btn_seek_bwd"
                android:nextFocusRight="@id/btn_seek_fwd" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_seek_fwd"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_fast_forward"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusLeft="@id/btn_play"
                android:nextFocusRight="@id/btn_next" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_skip_next"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusLeft="@id/btn_seek_fwd" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
