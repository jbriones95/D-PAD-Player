<?xml version="1.0" encoding="utf-8"?>
<!--
  Track row: playing indicator | album art | title+artist | three-dot menu
  Inspired by anrimian's item_storage_music.xml layout.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/item_track_height"
    android:paddingTop="@dimen/item_track_padding_v"
    android:paddingBottom="@dimen/item_track_padding_v"
    android:paddingStart="@dimen/item_track_padding_h"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:background="@android:color/transparent">

    <!-- Left playing indicator bar -->
    <View
        android:id="@+id/playing_indicator"
        android:layout_width="@dimen/playing_indicator_width"
        android:layout_height="0dp"
        android:background="?attr/colorPrimary"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@+id/tv_item_art"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_item_art" />

    <!-- Album art thumbnail -->
    <ImageView
        android:id="@+id/tv_item_art"
        android:layout_width="@dimen/item_track_art_size"
        android:layout_height="@dimen/item_track_art_size"
        android:scaleType="centerCrop"
        android:contentDescription="Album art"
        android:layout_marginStart="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/playing_indicator"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title — primary text -->
    <TextView
        android:id="@+id/tv_item_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="4dp"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="?android:attr/textColorPrimary"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintBottom_toTopOf="@+id/tv_item_artist"
        app:layout_constraintEnd_toStartOf="@+id/btn_track_menu"
        app:layout_constraintStart_toEndOf="@+id/tv_item_art"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Artist · duration — secondary text -->
    <TextView
        android:id="@+id/tv_item_artist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="4dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?android:attr/textColorSecondary"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_track_menu"
        app:layout_constraintStart_toEndOf="@+id/tv_item_art"
        app:layout_constraintTop_toBottomOf="@+id/tv_item_title" />

    <!-- Three-dot overflow menu button (anrimian-style) -->
    <ImageView
        android:id="@+id/btn_track_menu"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_more_vert"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:clickable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="More options"
        app:tint="?android:attr/textColorSecondary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Hidden duration field (kept for adapter compat, not displayed) -->
    <TextView
        android:id="@+id/tv_item_duration"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Clickable overlay matching anrimian pattern: D-pad focus and click are applied to this frame -->
    <FrameLayout
        android:id="@+id/clickable_item"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:focusable="true"
        android:focusableInTouchMode="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
