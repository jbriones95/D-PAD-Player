<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Header bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/colorPrimary"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tv_home_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="DPad Player"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnPrimary"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="48dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- iPod menu list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_menu"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:descendantFocusability="afterDescendants" />

    <!-- Mini now-playing bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mini_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:elevation="4dp"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:clickable="true">

        <ImageView
            android:id="@+id/mini_art"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note"
            android:layout_margin="8dp"
            android:contentDescription="Album art"
            app:layout_constraintBottom_toTopOf="@+id/mini_progress"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/mini_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            android:text="No track playing"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="false"
            android:singleLine="true"
            app:layout_constraintBottom_toTopOf="@+id/mini_artist"
            app:layout_constraintEnd_toStartOf="@+id/mini_btn_play"
            app:layout_constraintStart_toEndOf="@+id/mini_art"
            app:layout_constraintTop_toTopOf="@+id/mini_art"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/mini_artist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            android:text=""
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorSecondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintBottom_toBottomOf="@+id/mini_art"
            app:layout_constraintEnd_toStartOf="@+id/mini_btn_play"
            app:layout_constraintStart_toEndOf="@+id/mini_art"
            app:layout_constraintTop_toBottomOf="@+id/mini_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mini_btn_play"
            style="@style/Widget.MaterialComponents.Button.Icon"
            app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:text=""
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusRight="@id/mini_btn_next"
            app:layout_constraintBottom_toTopOf="@+id/mini_progress"
            app:layout_constraintEnd_toStartOf="@+id/mini_btn_next"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mini_btn_next"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
            app:icon="@drawable/ic_skip_next"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:text=""
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusLeft="@id/mini_btn_play"
            app:layout_constraintBottom_toTopOf="@+id/mini_progress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/mini_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:trackThickness="3dp"
            app:indicatorColor="?attr/colorPrimary"
            app:trackColor="?attr/colorSurfaceVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
