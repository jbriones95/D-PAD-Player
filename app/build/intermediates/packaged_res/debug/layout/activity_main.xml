<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout for 369x492dp (480x640px @208dpi) device.
  Player panel ~135dp, track list fills the rest.
  Icon-only buttons, Auxio-style compact bar.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ── Track list ──────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/track_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:descendantFocusability="afterDescendants"
        android:clipToPadding="false"
        android:paddingBottom="4dp" />

    <!-- ── Now-Playing panel (Auxio compact bar style) ────────────── -->
    <LinearLayout
        android:id="@+id/player_panel"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/player_padding_h"
        android:paddingEnd="@dimen/player_padding_h"
        android:paddingTop="@dimen/player_padding_v"
        android:paddingBottom="@dimen/player_padding_v"
        android:background="?attr/colorSurfaceVariant"
        android:elevation="4dp">

        <!-- Row 1: album art + title/artist + track counter -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/player_panel_info_height"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/album_art"
                android:layout_width="@dimen/player_album_art_size"
                android:layout_height="@dimen/player_album_art_size"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note"
                android:layout_marginEnd="10dp"
                android:contentDescription="Album art" />

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No track"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_album"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_track_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Row 2: seekbar + timestamps -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/player_seek_row_height"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_position"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textSize="10sp"
                android:gravity="start" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="false" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Row 3: transport controls (icon-only, Auxio-style) -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/player_control_btn_height"
            android:gravity="center"
            android:layout_marginTop="2dp">

            <!-- |< Prev -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_prev"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_skip_previous"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:nextFocusRight="@id/btn_seek_bwd"
                android:nextFocusDown="@id/seek_bar"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <!-- <<  Seek back -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_seek_bwd"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_fast_rewind"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:nextFocusLeft="@id/btn_prev"
                android:nextFocusRight="@id/btn_play"
                android:nextFocusDown="@id/seek_bar"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <!-- ▶/⏸ Play-Pause (wider) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play"
                style="@style/Widget.MaterialComponents.Button.Icon"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:nextFocusLeft="@id/btn_seek_bwd"
                android:nextFocusRight="@id/btn_seek_fwd"
                android:nextFocusDown="@id/seek_bar"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <!-- >> Seek forward -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_seek_fwd"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_fast_forward"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:nextFocusLeft="@id/btn_play"
                android:nextFocusRight="@id/btn_next"
                android:nextFocusDown="@id/seek_bar"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <!-- >| Next -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                app:icon="@drawable/ic_skip_next"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:nextFocusLeft="@id/btn_seek_fwd"
                android:nextFocusDown="@id/seek_bar"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
