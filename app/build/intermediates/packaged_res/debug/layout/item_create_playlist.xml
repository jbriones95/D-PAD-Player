<?xml version="1.0" encoding="utf-8"?>
<!-- Header row: "Create playlist" — always first in the Playlists RecyclerView -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/item_track_height"
    android:paddingStart="@dimen/item_track_padding_h"
    android:paddingEnd="@dimen/item_track_padding_h"
    android:paddingTop="@dimen/item_track_padding_v"
    android:paddingBottom="@dimen/item_track_padding_v"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/iv_create_icon"
        android:layout_width="@dimen/item_track_art_size"
        android:layout_height="@dimen/item_track_art_size"
        android:scaleType="centerInside"
        android:src="@drawable/ic_add"
        android:contentDescription="Create playlist"
        app:tint="?attr/colorPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_create_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="Create playlist"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="?attr/colorPrimary"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_create_icon"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
