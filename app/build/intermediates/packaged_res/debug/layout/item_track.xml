<?xml version="1.0" encoding="utf-8"?>
<!--
  Auxio-style song row: small album thumb + title/artist + duration
  Height: ~52dp (item_track_height)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="@dimen/item_track_height"
    android:paddingStart="@dimen/item_track_padding_h"
    android:paddingEnd="@dimen/item_track_padding_h"
    android:paddingTop="@dimen/item_track_padding_v"
    android:paddingBottom="@dimen/item_track_padding_v"
    android:gravity="center_vertical"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:background="?attr/selectableItemBackground">

    <!-- Playing indicator (left edge bar) -->
    <View
        android:id="@+id/playing_indicator"
        android:layout_width="@dimen/playing_indicator_width"
        android:layout_height="28dp"
        android:layout_marginEnd="6dp"
        android:background="?attr/colorPrimary"
        android:visibility="invisible" />

    <!-- Album art thumbnail -->
    <ImageView
        android:id="@+id/tv_item_art"
        android:layout_width="@dimen/item_track_art_size"
        android:layout_height="@dimen/item_track_art_size"
        android:scaleType="centerCrop"
        android:layout_marginEnd="10dp"
        android:contentDescription="Album art" />

    <!-- Title + Artist stacked -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tv_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_item_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Duration -->
    <TextView
        android:id="@+id/tv_item_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textSize="10sp"
        android:layout_marginStart="6dp" />

</LinearLayout>
