<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Theme -->
    <ListPreference
        app:key="theme"
        app:title="Theme"
        app:summary="%s"
        app:entries="@array/pref_theme_labels"
        app:entryValues="@array/pref_theme_values"
        app:defaultValue="system"
        app:useSimpleSummaryProvider="true"
        app:icon="@drawable/ic_settings_theme" />

    <!-- Accent color -->
    <ListPreference
        app:key="accent"
        app:title="Accent color"
        app:summary="%s"
        app:entries="@array/pref_accent_labels"
        app:entryValues="@array/pref_accent_values"
        app:defaultValue="deep_purple"
        app:useSimpleSummaryProvider="true"
        app:icon="@drawable/ic_settings_theme" />

    <!-- Seek / skip duration -->
    <ListPreference
        app:key="seek_step"
        app:title="Seek and skip duration"
        app:summary="%s"
        app:entries="@array/pref_seek_labels"
        app:entryValues="@array/pref_seek_values"
        app:defaultValue="15000"
        app:useSimpleSummaryProvider="true"
        app:icon="@drawable/ic_settings_seek" />

    <!-- Sort order -->
    <ListPreference
        app:key="sort_order"
        app:title="Sort tracks by"
        app:summary="%s"
        app:entries="@array/pref_sort_labels"
        app:entryValues="@array/pref_sort_values"
        app:defaultValue="title"
        app:useSimpleSummaryProvider="true"
        app:icon="@drawable/ic_settings_sort" />

    <!-- Show / hide top library bar (tabs + pager) to favour iPod-style navigation -->
    <SwitchPreferenceCompat
        app:key="show_top_bar"
        app:title="Show top library bar"
        app:defaultValue="true"
        app:summary="When off, the tab bar and pager are hidden for a simpler iPod-like experience"
        app:icon="@drawable/ic_settings_theme" />

</PreferenceScreen>
