# === Basic ignores for Android projects ===

# Gradle
/.gradle
/build
**/build

# Android Studio / IntelliJ
/.idea
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/shelf/
*.iml

# Local config
local.properties

# APKs and bundles
*.apk
*.ap_
*.aab

# Keystores
*.jks
*.keystore

# Native build
/.externalNativeBuild/
/.cxx/

# OS files
.DS_Store
Thumbs.db

# VSCode
.vscode/

# Logs, temp files and editor swap
*.log
*.tmp
*.swp

# Misc env files
.env
.env.*

# Generated outputs in repo
app/build/
app/*.iml
**/app-*.apk
app/**/outputs/

# Screenshots, captures and quick debug artifacts
capture_*.png
/tmp/*.png
*.screen.png

# Launcher assets generated during development (keep placeholders tracked if desired)
app/src/main/res/mipmap-*/ic_launcher*.png
app/src/main/res/mipmap-anydpi-v26/ic_launcher*.xml
app/src/main/res/drawable/app_icon_source.png

# Avoid committing large archives or JDKs accidentally
jdk*/
*.tar.gz
